    "regex_rules": {
      "recommendation_patterns": [
        "(?:来点|给我|帮我找|帮我推荐|推荐几道|推荐几款|找几道|找几个)"
      ],
      "time_minutes_patterns": [
        "(\\d+(?:\\.\\d+)?)\\s*分钟"
      ],
      "time_hours_patterns": [
        "(\\d+(?:\\.\\d+)?)\\s*小时"
      ],
      "time_half_hour_patterns": [
        "半小时"
      ],
      "excluded_term_patterns": [
        "(?:不要|不能|不吃|不含|排除|去掉)([\\u4e00-\\u9fffA-Za-z0-9]{1,16})",
        "([\\u4e00-\\u9fffA-Za-z0-9]{1,16})(?:不要|不放)"
      ],
      "pairwise_entity_patterns": [
        "从([\\u4e00-\\u9fffA-Za-z0-9]{2,24})到([\\u4e00-\\u9fffA-Za-z0-9]{2,24})(?:之间|的关系路径|的路径|的链路|的关联)?",
        "([\\u4e00-\\u9fffA-Za-z0-9]{2,24})(?:和|与|跟)([\\u4e00-\\u9fffA-Za-z0-9]{2,24})(?:之间)?(?:的关系|关联|联系|影响|路径|链路)",
        "([\\u4e00-\\u9fffA-Za-z0-9]{2,24})对([\\u4e00-\\u9fffA-Za-z0-9]{2,24})(?:的影响|有哪些影响|有什么影响)"
      ],
      "entity_cleanup_prefix_patterns": [
        "^(?:为什么|怎么|如何)+",
        "^(?:这个|这道|这款|这份|这种|这些|那个|那道|那种|那类|请问|帮我|给我|来点)+",
        "^(?:和|与|跟|从|到|对|把|将|关于)+",
        "^(?:\\d+(?:分钟|小时)|半小时)(?:内|以内)?"
      ],
      "entity_cleanup_suffix_patterns": [
        "(?:能|会)+$",
        "(?:的菜|菜肴|菜品|做法|搭配|推荐|适合|类似|相似|关系|原因|影响|形成|联系|关联|路径|链路|中间节点|节点|关系类型)+$",
        "(?:吗|呢|呀|啊|吧)+$"
      ],
      "graph_context_suffix_patterns": [
        "(?:在知识图谱里|在知识图谱中|知识图谱里|知识图谱中)+$"
      ]
    }
