# Copy this file to .env for local use. Keep real secrets only in .env.
# .env is ignored by Git; .env.example should contain placeholders and safe defaults.

# DashScope / Alibaba Cloud Model Studio API key
DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_SECONDS=30
NEO4J_MAX_CONNECTION_LIFETIME_SECONDS=3600
NEO4J_CONNECTION_TIMEOUT_SECONDS=15

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=cooking_knowledge
MILVUS_BLUE_GREEN_ENABLED=true
MILVUS_COLLECTION_ALIAS_SUFFIX=__active
# Must match EMBEDDING_DIMENSION
MILVUS_DIMENSION=1024
ARTIFACT_MANIFEST_PATH=storage/indexes/artifact_manifest.json
BUILD_JOB_STORE_PATH=storage/indexes/build_jobs.json

# Models
EMBEDDING_MODEL=qwen3-vl-embedding
LLM_MODEL=qwen3.7-plus
RERANK_MODEL=qwen3-vl-rerank
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=10
ENABLE_RERANK=true
LLM_TIMEOUT_SECONDS=20
EMBEDDING_TIMEOUT_SECONDS=60
RERANK_TIMEOUT_SECONDS=20
HTTP_POOL_CONNECTIONS=10
HTTP_POOL_MAXSIZE=20
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=30
GENERATION_TIMEOUT_SECONDS=20
GENERATION_STREAM_TIMEOUT_SECONDS=20
GENERATION_LATENCY_BUDGET_SECONDS=24
GENERATION_MAX_RETRIES=1
GENERATION_REQUEST_RETRIES=1
GENERATION_STREAM_RETRIES=1

# Endpoints
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
SERVING_API_HOST=0.0.0.0
SERVING_API_PORT=8000
SERVING_API_RELOAD=false
API_AUTO_INITIALIZE_SERVING=false
BUILD_API_HOST=0.0.0.0
BUILD_API_PORT=8001
BUILD_API_RELOAD=false
BUILD_API_AUTO_INITIALIZE=false
SERVING_HOT_REFRESH_ENABLED=true
SERVING_HOT_REFRESH_INTERVAL_SECONDS=2

# API security
# Generate a long random value for production. Protected endpoints fail closed
# when authentication is enabled and this token is empty.
API_AUTH_ENABLED=true
API_ACCESS_TOKEN=replace_with_a_long_random_token
API_MAX_REQUEST_BODY_BYTES=16384

# Retrieval / generation
TOP_K=5
VECTOR_SEARCH_EF=128
VECTOR_SEARCH_MAX_K=50
QUERY_PLAN_CACHE_SIZE=128
FAST_RULE_QUERY_PLANNING=true
QUERY_PLANNER_LLM_TEMPERATURE=0.0
QUERY_PLANNER_LLM_MAX_TOKENS=1200
QUERY_SEMANTIC_RELATION_INTENSITY_REFERENCE_RATIO=0.5
QUERY_SEMANTIC_COMPLEXITY_RELATION_HIT_WEIGHT=0.14
QUERY_SEMANTIC_COMPLEXITY_CONSTRAINT_HIT_WEIGHT=0.10
QUERY_SEMANTIC_COMPLEXITY_STRUCTURAL_HIT_WEIGHT=0.12
QUERY_SEMANTIC_COMPLEXITY_LENGTH_WEIGHT=0.28
QUERY_SEMANTIC_COMPLEXITY_LENGTH_NORM_CHARS=140
QUERY_SEMANTIC_REASONING_COMPLEXITY_THRESHOLD=0.7
QUERY_SEMANTIC_REASONING_RELATIONSHIP_THRESHOLD=0.4
QUERY_SEMANTIC_HIGH_RELATIONSHIP_ROUTING_THRESHOLD=0.7
QUERY_SEMANTIC_RELATION_HIT_INTENSITY_BOOST_BASE=0.45
QUERY_SEMANTIC_RELATION_HIT_INTENSITY_BOOST_STEP=0.12
QUERY_SEMANTIC_RELATION_HIT_COMPLEXITY_BOOST_BASE=0.55
QUERY_SEMANTIC_RELATION_HIT_COMPLEXITY_BOOST_STEP=0.08
QUERY_SEMANTIC_SOURCE_ENTITY_LIMIT=3
QUERY_SEMANTIC_ENTITY_KEYWORD_LIMIT=4
QUERY_SEMANTIC_PROFILE_ENTITY_KEYWORD_LIMIT=6
QUERY_SEMANTIC_TOPIC_KEYWORD_LIMIT=4
QUERY_SEMANTIC_PROFILE_TOPIC_KEYWORD_START=4
QUERY_SEMANTIC_PROFILE_TOPIC_KEYWORD_LIMIT=6
QUERY_SEMANTIC_TARGET_ENTITY_LIMIT=2
QUERY_SEMANTIC_MULTI_HOP_HINT_ENTITY_COUNT=2
QUERY_SEMANTIC_MULTI_HOP_HINT_RELATIONSHIP_THRESHOLD=0.55
QUERY_SEMANTIC_COMBINED_STRATEGY_RELATIONSHIP_THRESHOLD=0.4
QUERY_SEMANTIC_COMBINED_STRATEGY_COMPLEXITY_THRESHOLD=0.6
QUERY_SEMANTIC_SOURCE_ENTITY_SEED_RELATIONSHIP_THRESHOLD=0.4
QUERY_SEMANTIC_SOURCE_ENTITY_BACKFILL_RELATIONSHIP_THRESHOLD=0.55
QUERY_SEMANTIC_RULE_FALLBACK_CONFIDENCE=0.45
QUERY_SEMANTIC_ENTITY_RELATION_MAX_DEPTH=1
QUERY_SEMANTIC_PATH_FINDING_MAX_DEPTH=3
QUERY_SEMANTIC_PATH_FINDING_HIGH_INTENSITY_MAX_DEPTH=4
QUERY_SEMANTIC_PATH_FINDING_HIGH_INTENSITY_THRESHOLD=0.6
QUERY_SEMANTIC_SUBGRAPH_MAX_DEPTH=2
QUERY_SEMANTIC_SUBGRAPH_HIGH_INTENSITY_MAX_DEPTH=3
QUERY_SEMANTIC_SUBGRAPH_HIGH_INTENSITY_THRESHOLD=0.5
QUERY_SEMANTIC_CLUSTERING_MAX_DEPTH=3
QUERY_SEMANTIC_DEFAULT_MAX_DEPTH=2
QUERY_SEMANTIC_DEFAULT_HIGH_INTENSITY_MAX_DEPTH=3
QUERY_SEMANTIC_DEFAULT_HIGH_INTENSITY_THRESHOLD=0.7
QUERY_SEMANTIC_ENTITY_RELATION_MAX_NODES=20
QUERY_SEMANTIC_PATH_FINDING_MAX_NODES=40
QUERY_SEMANTIC_SUBGRAPH_MAX_NODES=80
QUERY_SEMANTIC_CLUSTERING_MAX_NODES=60
QUERY_SEMANTIC_DEFAULT_MAX_NODES=50
QUERY_SEMANTIC_GRAPH_QUERY_MAX_DEPTH_CAP=4
QUERY_SEMANTIC_GRAPH_QUERY_FALLBACK_NAME_CHARS=16
QUERY_SEMANTIC_ADAPTIVE_MULTI_HOP_SUBGRAPH_THRESHOLD=0.7
QUERY_SEMANTIC_ADAPTIVE_SUBGRAPH_MULTI_HOP_THRESHOLD=0.45
QUERY_SEMANTIC_ADAPTIVE_ENTITY_RELATION_MULTI_HOP_THRESHOLD=0.5
QUERY_SEMANTIC_ADAPTIVE_SUBGRAPH_MAX_DEPTH=3
QUERY_SEMANTIC_ADAPTIVE_SUBGRAPH_MAX_NODES=100
QUERY_SEMANTIC_ADAPTIVE_MULTI_HOP_MAX_DEPTH=3
QUERY_SEMANTIC_ADAPTIVE_MULTI_HOP_MAX_NODES=50
QUERY_SEMANTIC_ADAPTIVE_ENTITY_RELATION_MAX_DEPTH=2
QUERY_SEMANTIC_ADAPTIVE_ENTITY_RELATION_MAX_NODES=40
HYBRID_DEFAULT_CANDIDATE_MULTIPLIER=2
HYBRID_DEFAULT_CANDIDATE_MIN_CANDIDATES=10
HYBRID_CONSTRAINT_CANDIDATE_MULTIPLIER=6
HYBRID_CONSTRAINT_CANDIDATE_MIN_CANDIDATES=30
ROUTER_COMBINED_CANDIDATE_MULTIPLIER=6
ROUTER_COMBINED_CANDIDATE_MIN_CANDIDATES=30
ROUTER_GRAPH_SUPPLEMENT_CANDIDATE_MULTIPLIER=2
ROUTER_GRAPH_SUPPLEMENT_CANDIDATE_MIN_CANDIDATES=10
RETRIEVAL_CANDIDATE_SOURCE_FAILURE_THRESHOLD=1
RETRIEVAL_CANDIDATE_SOURCE_RECOVERY_SECONDS=30
# continue records degraded source details and keeps other sources running; fail_fast raises.
RETRIEVAL_CANDIDATE_SOURCE_DEGRADATION_STRATEGY=continue
RETRIEVAL_PRESERVE_GRAPH_EVIDENCE=true
ENABLE_INDEX_CACHE=true
INDEX_CACHE_DIR=storage/indexes
ENABLE_SEMANTIC_GRAPH_SCHEMA=true
ENABLE_QUERY_TRACING=true
QUERY_TRACE_PATH=storage/traces/query_trace.jsonl
QUERY_TRACE_ASYNC_ENABLED=true
QUERY_TRACE_MAX_QUEUE_SIZE=256
# Set a deployment-specific secret to make trace fingerprints stable across restarts.
# When empty, each process uses an ephemeral random salt.
QUERY_TRACE_FINGERPRINT_SALT=
ENABLE_OPENTELEMETRY=false
OTEL_SERVICE_NAME=graphrag
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACE_SAMPLE_RATIO=1.0
ENABLE_PROMETHEUS=true
LLM_INPUT_COST_PER_MILLION_TOKENS=0
LLM_OUTPUT_COST_PER_MILLION_TOKENS=0
ENABLE_PARENT_DOC_RETRIEVAL=true
PARENT_DOC_TOP_N=3
PARENT_DOC_MAX_CHARS=4000
TEMPERATURE=0.1
MAX_TOKENS=2048
CHUNK_SIZE=500
CHUNK_OVERLAP=50
LOG_LEVEL=INFO
